from collections import deque

# Graph representation using adjacency list
graph = {
'A': ['B', 'C'],
'B': ['D', 'E'],
'C': ['F'],
'D': [],
'E': ['F'],
'F': []
}

# Breadth First Search
def bfs(start, goal):
visited = []
queue = deque([start])

while queue:
node = queue.popleft()

if node not in visited:
visited.append(node)

if node == goal:
print("Goal node found using BFS")
return visited

queue.extend(graph[node])

return visited


# Depth First Search
def dfs(start, goal):
visited = []
stack = [start]

while stack:
node = stack.pop()

if node not in visited:
visited.append(node)

if node == goal:
print("Goal node found using DFS")
return visited

stack.extend(graph[node])

return visited


start = 'A'
goal = 'F'

print("BFS Traversal:", bfs(start, goal))
print("DFS Traversal:", dfs(start, goal))

